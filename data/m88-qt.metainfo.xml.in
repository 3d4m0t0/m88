<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.3d4m0t0.m88-qt</id>
  <name>M88</name>
  <summary>PC-8801 series emulator</summary>
  <summary xml:lang="ja">PC-8801 シリーズ エミュレータ</summary>
  <summary xml:lang="zh-CN">PC-8801 系列模拟器</summary>
  <summary xml:lang="zh-TW">PC-8801 系列模擬器</summary>
  <summary xml:lang="ko">PC-8801 시리즈 에뮬레이터</summary>
  <summary xml:lang="de">PC-8801-Emulator</summary>
  <summary xml:lang="fr">Émulateur série PC-8801</summary>
  <summary xml:lang="es">Emulador serie PC-8801</summary>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>BSD-2-Clause</project_license>
  <description>
    <p>
      Linux port of the M88 PC-8801 emulator with a Qt 6 frontend.
      Requires legally obtained ROM files from hardware you own.
    </p>
    <p xml:lang="ja">M88 PC-8801 エミュレータの Linux (Qt 6) 移植版です。 所有する実機から吸い出した ROM ファイルが必要です。</p>
    <p xml:lang="zh-CN">M88 PC-8801 模拟器的 Linux (Qt 6) 移植版。需要您拥有并从实机导出的 ROM 文件。</p>
    <p xml:lang="zh-TW">M88 PC-8801 模擬器的 Linux (Qt 6) 移植版。需要您擁有並從實機匯出的 ROM 檔案。</p>
    <p xml:lang="ko">M88 PC-8801 에뮬레이터의 Linux (Qt 6) 포트입니다. 소유한 실기에서 덤프한 ROM 파일이 필요합니다.</p>
    <p xml:lang="de">Linux-Port des M88 PC-8801-Emulators mit Qt-6-Oberfläche. Erfordert legal erworbene ROM-Dateien von eigener Hardware.</p>
    <p xml:lang="fr">Port Linux de l'émulateur M88 PC-8801 avec interface Qt 6. Nécessite des fichiers ROM obtenus légalement depuis un matériel que vous possédez.</p>
    <p xml:lang="es">Port Linux del emulador M88 PC-8801 con interfaz Qt 6. Requiere archivos ROM obtenidos legalmente del hardware que posea.</p>
  </description>
  <launchable type="desktop-id">m88-qt.desktop</launchable>
  <url type="homepage">https://github.com/3d4m0t0/m88</url>
  <developer id="io.github.3d4m0t0">
    <name>3d4m0t0</name>
  </developer>
  <releases>
    <release version="@M88_PORT_VERSION@" date="@M88_RELEASE_DATE@"/>
  </releases>
  <content_rating type="oars-1.1"/>
</component>
